<MudPaper Class=" pa-1 align-start d-flex" Style="width: 300px;">
    <MudPaper Class="pa-4" Elevation="0">
        <MudText Align="Align.Left" Color="Color.Primary">
            Request Valuation Review
        </MudText>
    </MudPaper>

    <MudSpacer />

    <MudPaper Class="pa-3" Elevation="0">
        <MudIconButton Variant="Variant.Outlined"
                       Icon="@Icons.Material.Filled.Email"
                       Color="Color.Warning"
                       OnClick="(() => OnRequestObjectionClicked())">
                   
        </MudIconButton>
    </MudPaper>

</MudPaper>

@code {

    [Parameter]
    public PropertyRecord propertyRecord { get; set; } = default!;

    private void OnRequestObjectionClicked()
    {
        // Navigate to the objection submission page
        state.Set(propertyRecord);
        navigationManager.NavigateTo("/submit-review");
    }
}
