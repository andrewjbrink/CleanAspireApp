@page "/tenders"

@using CleanAspireApp.Domain.Tenders
@using CleanAspireApp.Application.UseCases.Tenders.States
@using CleanAspireApp.Web.Extensions
@inject CleanAspireApp.Web.Services.TenderService tenderService

@inject ISnackbar snackbar
@inject NavigationManager NavigationManager
@inject TenderState tenderState
@inject JavaHelper javaHelper


@* https://www.tutorialpedia.org/blog/cancellationtoken-in-blazor-pages/ *@

