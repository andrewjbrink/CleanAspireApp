@page "/submit-review"
@using CleanAspireApp.Domain.ValuationRoll
@using CleanAspireApp.Web.Services
@using System.ComponentModel.DataAnnotations
@using CleanAspireApp.Web.Interfaces
@using CleanAspireApp.Domain.Common.Base
@inject ISnackbar Snackbar
@inject IEmailService EmailService
@inject ObjectionState state

@if (record is not null) 
{
     <MudText Color="Color.Primary" Align="Align.Center" Typo="Typo.h5">
        Submit Review for @record.Description
     </MudText>
    <br/>
    
}
 @* <MudText Align="Align.Left" GutterBottom="true">
    If you wish to have valuation of this property reviewed, please complete this form.
    <br />
    We currently partner with Valunation.
    For more information on them, you can refer to the following link:
</MudText> 
<MudLink Href="https://valunation.co.za/" Target="_blank" Typo="Typo.body2" Color="Color.Primary">
    More details
</MudLink> *@



<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-6 rounded-lg">
        @* <MudText Typo="Typo.h4" Class="mb-4">Contact Us</MudText> *@

        <MudForm @ref="form" Model="contactModel">
            <MudTextField T="string"
                          Label="Your Email Address"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Email is required"
                          @bind-Value="contactModel.Email"
                          For="@(() => contactModel.Email)" />
            <MudTextField T="string"
                          Label="Your Name"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Name is required"
                          @bind-Value="contactModel.Name"
                          For="@(() => contactModel.Name)" />

            <MudTextField T="string"
                          Label="Your contact number"
                          Variant="Variant.Outlined"
                          Required="true"
                          RequiredError="Contact number is required"
                          @bind-Value="contactModel.ContactNumber"
                          For="@(() => contactModel.ContactNumber)" />

            <MudTextField T="string"
                          Label="Message"
                          Variant="Variant.Outlined"
                          Lines="6"
                          Text="@contactModel.Message"
                          TextChanged="@(v => contactModel.Message = v)"
                          Required="true"
                          RequiredError="Message is required"
                          For="@(() => contactModel.Message)"
                          Class="mt-4"
                          AutoGrow="true"
                          Immediate="true" />

            <!-- Honeypot Field (hidden from users, bots often fill it) -->
            <MudTextField T="string"
                          Label=""
                          @bind-Value="contactModel.Website"
                          Style="display:none;"
                          TabIndex="-1" />

            <!-- Simple Math CAPTCHA -->
            <MudText Typo="Typo.body1" Class="mt-4">What is @captchaA + @captchaB?</MudText>
            <MudTextField T="int?"
                          Label="Captcha"
                          Variant="Variant.Outlined"
                          @bind-Value="contactModel.CaptchaAnswer"
                          Required="true"
                          RequiredError="Captcha answer is required" />

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Class="mt-6"
                       Disabled="isSubmitting"
                       OnClick="(()=> SubmitForm())">
                @if (isSubmitting)
                {
                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="me-2" />
                    <span>Sending...</span>
                }
                else
                {
                    <span>Submit</span>
                }
            </MudButton>

           

        </MudForm>
    </MudPaper>
</MudContainer>

@code {

    private PropertyRecord record = default!;
    private MudForm? form;
    private int captchaA = Random.Shared.Next(1, 10);
    private int captchaB = Random.Shared.Next(1, 10);
    private bool isSubmitting;

    private ContactModel contactModel = new();

    override protected void OnInitialized()
    {
        var cached = state.SelectedItem;
        if (cached != null)
        {
            record = cached;
        }
    }

    private async Task SubmitForm()
    {
        // await form!.ValidateAsync();

        // if(!form.IsValid)
        // {
        //     Snackbar.Add("Please fill in all required fields correctly.", Severity.Error);
        //     return;
        // };
        isSubmitting = true;

        try
        {
            // Honeypot spam protection
            if (!string.IsNullOrWhiteSpace(contactModel.Website))
            {
                Snackbar.Add("Spam detected.", Severity.Error);
                return;
            }

            // Captcha validation
            if (contactModel.CaptchaAnswer != (captchaA + captchaB))
            {
                Snackbar.Add("Incorrect captcha answer.", Severity.Error);
                return;
            }

            
            await EmailService.SendReviewAsync(contactModel, record);

            Snackbar.Add("Your message has been sent successfully!", Severity.Success);
            contactModel = new ContactModel();
            await form!.ResetAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to send message: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSubmitting = false;
        }
    }
    
}
