@page "/current"

@using CleanAspireApp.Application.UseCases.Valuations.States
@using CleanAspireApp.Domain.ValuationRoll
@using CleanAspireApp.Web.Extensions
@using CleanAspireApp.Web.Services
@using Newtonsoft.Json


@inject IJSRuntime _jsRuntime
@inject EnqNotifier notifier
@inject ValuationService valuationService
@inject ValuationStateMany state
@inject JavaHelper javaHelper
@inject ISnackbar snackbar

@if (isScheme)
{
    <SchemeUnits  propertyRecords ="@propertyRecords" />
}
else
{
    <PropertyRecordCard propertyRecord="@thisProperty" />
}

@code
{
    private List<PropertyRecord> propertyRecords = default!;
    private PropertyRecord? thisProperty = default!;
    private bool isScheme = false;

    private void SelectedCallback(PropertyRecord selected)
    {
        thisProperty = selected;
    }


    override protected async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var thisEndpoint = await javaHelper.GetItemAsync("endpoint") ?? null;
            var lastValuation = await javaHelper.GetItemAsync("lastValuation") ?? null;
            if (lastValuation is not null)
            {
                thisProperty = JsonConvert.DeserializeObject<PropertyRecord>(lastValuation!);
                if(thisProperty != null && thisProperty.IsScheme) 
                {
                    var schemeName = thisProperty.SCHEME_NAME;
                    isScheme = true;
                    var cached = state.Get(schemeName);
                    if(cached != null)
                    {
                        propertyRecords = cached;
                        StateHasChanged();
                    } else
                    {
                        snackbar.Add("This is a Scheme. Fetching the units...", Severity.Success);
                        propertyRecords = await valuationService.GetSSValuationsAsync(schemeName);
                        state.Set(schemeName, propertyRecords);
                        StateHasChanged();
                        snackbar.Clear();
                       
                        await notifier.NotifyEnqChanged(true);
                    }
                }else
                {
                    isScheme = false;
                    StateHasChanged();
                }
               
                await notifier.NotifyEnqChanged(true);
            }
            else
            {
                snackbar.Add("No property enquiry found.", Severity.Info);
            }
        }
    }

    

