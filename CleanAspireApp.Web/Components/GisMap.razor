@using CleanAspireApp.Web.Extensions
@using CleanAspireApp.Web.Services
@using Esri.ArcGISRuntime.Mapping
@inject IJSRuntime _jsRuntime
@inject MapService mapService
@inject JavaHelper javaHelper


@implements IAsyncDisposable

<div id="status"></div>
<div id="viewDiv" />
@code {
    private IJSObjectReference? module;

    
    override protected async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await _jsRuntime.InvokeAsync<IJSObjectReference>("import", "./js/main.js"); 
            await module.InvokeVoidAsync("initializeMapWrapper");
            // await module.InvokeVoidAsync("restoreMapState"); 
            // await module.InvokeVoidAsync("restoreGraphics");
        }
    }


    public async ValueTask DisposeAsync()
    {
        if (module != null)
        {
            // await module.InvokeVoidAsync("saveGraphics");
            // await module.DisposeAsync();
          
        }
    }
}
<style>
    #viewDiv {
        height: 90vh;
        width: 100%;
        
    }
  
    #info {
        box-sizing: border-box;
        padding: 15px;
        height: 225px;
        width: 350px;
        background: #232b2b;
        color: white;
        font-size: 16px;
        line-height: 30px;
        overflow: auto;
        overflow-wrap: break-word;
    }

        #info span {
            font-weight: 600;
            color: #f7be81;
        }

    .address-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        color: #f7be81;
    }

        .address-table thead {
            background: #f5f5f5;
            border-bottom: 2px solid #ccc;
        }

        .address-table th {
            padding: 8px 10px;
            text-align: left;
            font-weight: 600;
            border-right: 1px solid #ddd;
        }

            .address-table th:last-child {
                border-right: none;
            }

        .address-table td {
            padding: 8px 10px;
            border-bottom: 1px solid #e0e0e0; /* row separator */
            border-right: 1px solid #f0f0f0;
        }

            #address-table td:last-child {
                border-right: none;
            }

        /* Hover effect */
        .address-table tbody tr:hover {
            background-color: #f0f8ff;
            cursor: pointer;
        }

        /* Optional: selected row highlight */
        .address-table tbody tr.selected {
            background-color: #d7eaff;
        }

